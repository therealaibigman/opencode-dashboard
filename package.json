{
  "name": "opencode-dashboard",
  "private": true,
  "workspaces": [
    "apps/*",
    "packages/*"
  ],
  "scripts": {
    "dev": "npm -ws run dev",
    "build": "npm -ws run build",
    "lint": "npm -ws --if-present run lint",
    "typecheck": "npm -ws run typecheck",
    "check:migrations": "node scripts/check_migrations.js",
    "worker": "npm -w @ocdash/worker run dev",
    "db:generate": "npm -w @ocdash/db run generate",
    "db:migrate": "npm -w @ocdash/db run migrate",
    "test": "npm -ws --if-present run test"
  },
  "devDependencies": {
    "vitest": "^4.1.9"
  }
}

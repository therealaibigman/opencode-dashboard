# Database
DATABASE_URL=postgres://oc:oc@localhost:5432/oc

# Worker
WORKER_POLL_INTERVAL_MS=750

# OpenCode (worker integration)
# Set to 1 to run without any OpenCode credentials (CI/dev smoke testing)
OPENCODE_STUB=1
# Optional: force the model used by `opencode run` (format: provider/model)
# Example: openrouter/anthropic/claude-3.5-sonnet
OPENCODE_MODEL=
# Optional: kill long-running tool calls
OPENCODE_TIMEOUT_MS=600000

# Web
NEXT_PUBLIC_APP_NAME=OpenCode Dashboard
